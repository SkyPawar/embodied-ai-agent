# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Google Cloud TTS Configuration
GOOGLE_TTS_CREDENTIALS=path/to/google-credentials.json
TTS_LANGUAGE_CODE=en-US
TTS_VOICE_NAME=en-US-Neural2-C
TTS_SPEAKING_RATE=1.0
TTS_PITCH=0.0

# Agent Configuration
AGENT_NAME=Luna
AGENT_PERSONALITY=friendly, helpful, wise, mature, empathetic, with a touch of humor
AGENT_BACKGROUND=I'm an AI assistant designed to have genuine, warm conversations. I aim to be helpful while maintaining a natural, human-like communication style.

# Chat Configuration
MAX_CONVERSATION_HISTORY=20

# Debug
DEBUG=false
